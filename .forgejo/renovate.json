{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",

  // self-hosted
  "onboarding": false,
  "requireConfig": "ignored",
  "platform": "forgejo",
  "endpoint": "https://trev.zip/api/v1",
  "repositories": ["llc/rsync-action"],
  "allowedCommands": ["npm audit fix", "npm run build"],

  // repository
  "extends": ["config:recommended"],
  "addLabels": ["dep"],
  "customDatasources": {
    "debian-pool": {
      "defaultRegistryUrlTemplate": "https://deb.debian.org/debian/pool/main/{{ packageName }}/",
      "format": "html"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Debian package versions",
      "managerFilePatterns": ["/^src/action\\.ts$/"],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+) packageName=(?<packageName>\\S+)\\s+debVersion: \"(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "loose"
    }
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 0"], // sunday
    "skipInstalls": false,
    "postUpgradeTasks": {
      "commands": ["npm audit fix"]
    }
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["nix"],
      "addLabels": ["nix"]
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["actions"]
    },
    {
      "matchDatasources": ["custom.debian-pool"],
      "matchPackageNames": ["o/openssl"],
      "extractVersion": "^openssl_(?<version>[^_]+)_amd64\\.deb$",
      "versioning": "loose",
      "addLabels": ["debian"],
      "postUpgradeTasks": {
        "commands": ["npm run build"],
        "fileFilters": ["build/index.js"]
      }
    },
    {
      "matchDatasources": ["custom.debian-pool"],
      "matchPackageNames": ["r/rsync"],
      "extractVersion": "^rsync_(?<version>[^_]+)_amd64\\.deb$",
      "versioning": "loose",
      "addLabels": ["debian"],
      "postUpgradeTasks": {
        "commands": ["npm run build"],
        "fileFilters": ["build/index.js"]
      }
    },
    {
      "matchManagers": ["npm"],
      "rangeStrategy": "bump",
      "addLabels": ["node"],
      "postUpdateOptions": ["npmInstallTwice"]
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["dependencies"],
      "postUpgradeTasks": {
        "commands": ["npm run build"],
        "fileFilters": ["build/index.js"]
      }
    },
    {
      "matchManagers": ["npm"],
      "matchDepTypes": ["engines"],
      "enabled": false
    }
  ]
}
