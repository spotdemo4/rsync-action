{
  "name": "node-template",
  "version": "0.6.16",
  "description": "node.js template",
  "license": "MIT",
  "repository": {
    "url": "https://trev.zip/template/node"
  },
  "bin": {
    "node-template": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "rolldown -c",
    "dev": "rolldown -c && node build/index.js",
    "prepare": "rolldown -c && chmod +x build/index.js",
    "test": "node --test"
  },
  "devDependencies": {
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "rolldown": "^1.1.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
